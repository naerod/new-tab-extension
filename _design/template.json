20DC, U+20E1, U+20E5-20EF, U+2100-2112, U+2114-2115, U+2117-2121, U+2123-214F, U+2190, U+2192, U+2194-21AE, U+21B0-21E5, U+21F1-21F2, U+21F4-2211, U+2213-2214, U+2216-22FF, U+2308-230B, U+2310, U+2319, U+231C-2321, U+2336-237A, U+237C, U+2395, U+239B-23B7, U+23D0, U+23DC-23E1, U+2474-2475, U+25AF, U+25B3, U+25B7, U+25BD, U+25C1, U+25CA, U+25CC, U+25FB, U+266D-266F, U+27C0-27FF, U+2900-2AFF, U+2B0E-2B11, U+2B30-2B4C, U+2BFE, U+3030, U+FF5B, U+FF5D, U+1D400-1D7FF, U+1EE00-1EEFF;\n}\n/* old-permic */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"3ce2eca6-cf34-4e0e-a947-0ba613d0b173\") format('woff2');\n  unicode-range: U+0300, U+0306-0308, U+0313, U+0483, U+20DB, U+25CC, U+10350-1037A;\n}\n/* symbols */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"126c82f1-e4ce-41bc-874a-f076f483dd3c\") format('woff2');\n  unicode-range: U+0001-000C, U+000E-001F, U+007F-009F, U+20DD-20E0, U+20E2-20E4, U+2150-218F, U+2190, U+2192, U+2194-2199, U+21AF, U+21E6-21F0, U+21F3, U+2218-2219, U+2299, U+22C4-22C6, U+2300-243F, U+2440-244A, U+2460-24FF, U+25A0-27BF, U+2800-28FF, U+2921-2922, U+2981, U+29BF, U+29EB, U+2B00-2BFF, U+4DC0-4DFF, U+FFF9-FFFB, U+10140-1018E, U+10190-1019C, U+101A0, U+101D0-101FD, U+102E0-102FB, U+10E60-10E7E, U+1D2C0-1D2D3, U+1D2E0-1D37F, U+1F000-1F0FF, U+1F100-1F1AD, U+1F1E6-1F1FF, U+1F30D-1F30F, U+1F315, U+1F31C, U+1F31E, U+1F320-1F32C, U+1F336, U+1F378, U+1F37D, U+1F382, U+1F393-1F39F, U+1F3A7-1F3A8, U+1F3AC-1F3AF, U+1F3C2, U+1F3C4-1F3C6, U+1F3CA-1F3CE, U+1F3D4-1F3E0, U+1F3ED, U+1F3F1-1F3F3, U+1F3F5-1F3F7, U+1F408, U+1F415, U+1F41F, U+1F426, U+1F43F, U+1F441-1F442, U+1F444, U+1F446-1F449, U+1F44C-1F44E, U+1F453, U+1F46A, U+1F47D, U+1F4A3, U+1F4B0, U+1F4B3, U+1F4B9, U+1F4BB, U+1F4BF, U+1F4C8-1F4CB, U+1F4D6, U+1F4DA, U+1F4DF, U+1F4E3-1F4E6, U+1F4EA-1F4ED, U+1F4F7, U+1F4F9-1F4FB, U+1F4FD-1F4FE, U+1F503, U+1F507-1F50B, U+1F50D, U+1F512-1F513, U+1F53E-1F54A, U+1F54F-1F5FA, U+1F610, U+1F650-1F67F, U+1F687, U+1F68D, U+1F691, U+1F694, U+1F698, U+1F6AD, U+1F6B2, U+1F6B9-1F6BA, U+1F6BC, U+1F6C6-1F6CF, U+1F6D3-1F6D7, U+1F6E0-1F6EA, U+1F6F0-1F6F3, U+1F6F7-1F6FC, U+1F700-1F7FF, U+1F800-1F80B, U+1F810-1F847, U+1F850-1F859, U+1F860-1F887, U+1F890-1F8AD, U+1F8B0-1F8BB, U+1F8C0-1F8C1, U+1F900-1F90B, U+1F93B, U+1F946, U+1F984, U+1F996, U+1F9E9, U+1FA00-1FA6F, U+1FA70-1FA7C, U+1FA80-1FA89, U+1FA8F-1FAC6, U+1FACE-1FADC, U+1FADF-1FAE9, U+1FAF0-1FAF8, U+1FB00-1FBFF;\n}\n/* symbols2 */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"ce528289-3012-46ad-8857-af2654f52992\") format('woff2');\n  unicode-range: U+2000-2001, U+2004-2008, U+200A, U+23B8-23BD, U+2500-259F;\n}\n/* syriac */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"5376ee9c-9240-4b75-8cd3-b0744b2ab309\") format('woff2');\n  unicode-range: U+0303-0304, U+0307-0308, U+030A, U+0320, U+0323-0325, U+032D-032E, U+0330-0331, U+060C, U+061B-061C, U+061F, U+0621, U+0640, U+064B-0655, U+0660-066C, U+0670, U+0700-074F, U+0860-086A, U+1DF8, U+1DFA, U+200C-200F, U+25CC, U+2670-2671;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"95ae47a5-7e0f-4de4-87f3-b641939027d4\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"70336ae3-b1ca-48f8-8441-314825105ef7\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Google Sans Code';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"e5863ec6-0f3e-4188-8011-246070caeb07\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n<\u002Fstyle>\n\n<style>\n  :root{\n    /* Claude-inspired warm dark palette */\n    --bg:#17191a;\n    --bg-2:#111314;\n    --card:#212425;\n    --card-2:#24292a;\n    --hover:#2c3032;\n    --line:rgba(240,238,230,.08);\n    --line-2:rgba(240,238,230,.13);\n\n    /* Type — warm cream */\n    --ink:#ece9e1;        /* primary text */\n    --ink-2:#b7b2a6;      /* secondary */\n    --ink-3:#8b8678;      /* tertiary / labels */\n    --ink-4:#5e5a50;      /* faint */\n\n    /* Single accent — Claude coral, used sparingly */\n    --accent:#d97757;\n    --accent-soft:rgba(217,119,87,.15);\n    --accent-line:rgba(217,119,87,.45);\n\n    /* Finance only */\n    --up:#5fd0a0;\n    --down:#f07a7a;\n\n    --r:16px;\n    --r-sm:11px;\n    --gap:18px;\n\n    --font:'Google Sans','Google Sans Text','Product Sans','Helvetica Neue',Helvetica,system-ui,sans-serif;\n    --serif:'Source Serif 4',Georgia,'Times New Roman',serif;\n    --mono:'Google Sans Code',ui-monospace,'SF Mono',Menlo,monospace;\n  }\n\n  *{box-sizing:border-box;margin:0;padding:0}\n\n  html,body{height:100%}\n  body{\n    background:\n      radial-gradient(1200px 760px at 80% -10%, rgba(217,119,87,.07), transparent 62%),\n      var(--bg);\n    color:var(--ink);\n    font-family:var(--font);\n    font-optical-sizing:auto;\n    font-variation-settings:\"GRAD\" 0;\n    -webkit-font-smoothing:antialiased;\n    text-rendering:optimizeLegibility;\n    line-height:1.45;\n    letter-spacing:.1px;\n  }\n\n  .tnum{ font-variant-numeric:tabular-nums; font-feature-settings:\"tnum\" 1; }\n\n  .wrap{\n    max-width:1440px;\n    margin:0 auto;\n    padding:46px 48px 60px;\n    position:relative;\n  }\n\n  /* ---------- generic card ---------- */\n  .card{\n    background:linear-gradient(180deg,var(--card-2),var(--card));\n    border:1px solid var(--line);\n    border-radius:var(--r);\n    padding:20px 22px;\n  }\n  /* lighter, translucent surface for tile panels (raccourcis / IA) */\n  .card.soft{\n    background:rgba(240,238,230,.04);\n    border-color:rgba(240,238,230,.07);\n  }\n  /* raccourcis stretches to match the IA rapide bubble height; icons centered */\n  .card.soft.col10{ align-self:stretch; display:flex; flex-direction:column; }\n  .card.soft.col10 .grid-sc{ flex:1; display:grid; grid-template-columns:repeat(10,1fr); gap:14px 10px; align-content:center; justify-items:center; }\n  .card.soft.col10 .sc{ padding:0; gap:0; width:auto; align-items:center; }\n  .card.soft.col10 .sc .tile{ flex:none; box-sizing:border-box; width:48px; height:48px; aspect-ratio:1; border-radius:13px; }\n  .card.soft.col10 .sc .tile svg{ width:23px; height:23px; }\n  .card.soft.col10 .sc .lbl{ display:none; }\n  /* IA rapide bubble: matches raccourcis height, grid centered */\n  .card.soft.col2{ align-self:stretch; display:flex; }\n  .card.soft.col2 .ai-mini{ flex:1; align-content:center; }\n  .card-head{\n    display:flex; align-items:center; justify-content:space-between;\n    margin-bottom:16px;\n  }\n  .card.col12 .card-head{ margin-bottom:10px; }\n  .card-title{\n    font-size:12px; font-weight:500; letter-spacing:.12em; text-transform:uppercase;\n    color:var(--ink-3);\n  }\n  .card-action{ font-size:12px; color:var(--ink-3); text-decoration:none; }\n  .card-action:hover{ color:var(--accent); }\n\n  a{ color:inherit; }\n\n  /* keyboard focus — visible indigo ring */\n  a:focus-visible, button:focus-visible, input:focus-visible{\n    outline:2px solid var(--accent);\n    outline-offset:2px;\n    border-radius:8px;\n  }\n\n  /* ================= HERO ================= */\n  .hero{\n    display:grid;\n    grid-template-columns:1fr auto;\n    align-items:flex-end;\n    gap:40px;\n    margin-bottom:30px;\n  }\n  .greeting{ font-size:21px; color:var(--ink-2); font-weight:400; margin-bottom:4px; letter-spacing:0; }\n  .greeting b{ color:var(--ink); font-weight:500; }\n  .clock{\n    font-size:clamp(61px,7.65vw,105px);\n    font-weight:500;\n    line-height:.92;\n    letter-spacing:-.02em;\n    display:flex; align-items:baseline; gap:.06em;\n  }\n  .clock .sec{\n    font-size:.34em;\n    font-weight:400;\n    color:var(--ink-3);\n    letter-spacing:.01em;\n    margin-left:.12em;\n    transform:translateY(-.06em);\n  }\n  .date{ font-size:15px; color:var(--ink-3); margin-top:12px; letter-spacing:.2px; }\n  .date::first-letter{ text-transform:uppercase; }\n\n  .zones{ display:flex; gap:12px; }\n  .zone{\n    background:var(--card);\n    border:1px solid var(--line);\n    border-radius:var(--r-sm);\n    padding:13px 16px 12px;\n    min-width:104px;\n  }\n  .zone .city{ font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-3); margin-bottom:8px; }\n  .zone .ztime{ font-size:23px; font-weight:500; letter-spacing:.01em; }\n  .zone .zmeta{ font-size:11px; color:var(--ink-4); margin-top:3px; }\n\n  /* ================= SEARCH ================= */\n  .search{\n    display:flex; align-items:center; gap:10px;\n    background:var(--card);\n    border:1px solid var(--line);\n    border-radius:14px;\n    padding:7px 8px 7px 18px;\n    margin-bottom:30px;\n    transition:border-color .18s, background .18s;\n  }\n  .search:focus-within{ border-color:var(--accent-line); background:var(--card-2); }\n  .search .glass{ width:18px; height:18px; flex:none; color:var(--ink-3); }\n  .search input{\n    flex:1; background:transparent; border:0; outline:none;\n    color:var(--ink); font-family:var(--font); font-size:16px; padding:11px 4px;\n  }\n  .search input::placeholder{ color:var(--ink-4); }\n  .seg{\n    display:flex; background:var(--bg-2); border:1px solid var(--line); border-radius:10px; padding:3px; gap:2px;\n  }\n  .seg button{\n    appearance:none; border:0; background:transparent; cursor:pointer;\n    color:var(--ink-3); font-family:var(--font); font-size:13px; font-weight:500;\n    padding:8px 16px; border-radius:7px; transition:.15s;\n  }\n  .seg button:hover{ color:var(--ink-2); }\n  .seg button[aria-pressed=\"true\"]{ background:var(--accent-soft); color:var(--accent); }\n  .seg button[data-engine=\"google\"][aria-pressed=\"true\"]{ background:rgba(255,255,255,.09); color:var(--ink); }\n  .seg button[data-engine=\"gemini\"][aria-pressed=\"true\"]{ background:rgba(77,139,240,.16); color:#5b9bf5; }\n  .seg button[data-engine=\"claude\"][aria-pressed=\"true\"]{ background:rgba(217,119,87,.18); color:#e08a5f; }\n\n  /* ================= BENTO ================= */\n  .bento{ display:grid; grid-template-columns:repeat(12,1fr); gap:var(--gap); align-items:start; }\n  .col3{ grid-column:span 3; }\n  .col4{ grid-column:span 4; }\n  .col5{ grid-column:span 5; }\n  .col7{ grid-column:span 7; }\n  .col8{ grid-column:span 8; }\n  .col9{ grid-column:span 9; }\n  .col2{ grid-column:span 2; }\n  .col10{ grid-column:span 10; }\n  .col12{ grid-column:span 12; }\n\n  /* two independent stacked columns (masonry-style) */\n  .bento-col{ display:flex; flex-direction:column; gap:var(--gap); }\n  .bento-col.col8{ grid-column:span 8; }\n  .bento-col.col4{ grid-column:span 4; }\n  .duo{ display:grid; grid-template-columns:1fr 1fr; gap:var(--gap); }\n\n  /* ----- weather ----- */\n  .wx-now{ display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }\n  .wx-temp{ font-size:54px; font-weight:500; line-height:1; letter-spacing:-.02em; }\n  .wx-cond{ font-size:14px; color:var(--ink-2); margin-top:8px; }\n  .wx-sub{ font-size:12px; color:var(--ink-3); margin-top:3px; }\n  .wx-loc{ font-size:12px; color:var(--ink-3); text-align:right; }\n  .wx-glyph{ font-size:64px; color:var(--ink-2); margin-top:0; text-align:right; line-height:1; }\n  .wx-days{ display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:18px; padding-top:16px; border-top:1px solid var(--line); }\n  .wx-day{ text-align:center; }\n  .wx-day .d{ font-size:11px; color:var(--ink-3); text-transform:uppercase; letter-spacing:.06em; }\n  .wx-day .g{ font-size:18px; margin:6px 0 4px; color:var(--ink-2); }\n  .wx-day .t{ font-size:13px; }\n  .wx-day .t b{ font-weight:500; }\n  .wx-day .t span{ color:var(--ink-4); }\n\n  /* ----- stocks ----- */\n  .row{ display:flex; align-items:center; gap:14px; padding:11px 0; border-top:1px solid var(--line); }\n  .row:first-of-type{ border-top:0; }\n  .row .name{ font-size:14px; flex:1; min-width:0; }\n  .row .spark{ width:74px; height:30px; flex:none; }\n  .row .name small{ display:block; font-size:11px; color:var(--ink-4); margin-top:2px; }\n  .row .right{ text-align:right; }\n  .row .price{ font-size:14px; font-weight:500; }\n  .row .chg{ font-size:12px; margin-top:2px; }\n  .up{ color:var(--up); }\n  .down{ color:var(--down); }\n\n  /* ----- news ----- */\n  .news-item{ display:block; text-decoration:none; padding:11px 0; border-top:1px solid var(--line); }\n  .news-item:first-of-type{ border-top:0; }\n  .news-item .t{ font-size:14px; color:var(--ink); line-height:1.35; transition:color .15s; }\n  .news-item:hover .t{ color:var(--accent); }\n  .news-item .m{ font-size:11px; color:var(--ink-4); margin-top:5px; }\n  .news-item .m b{ color:var(--ink-3); font-weight:500; }\n\n  /* ----- shortcuts ----- */\n  .grid-sc{ display:flex; flex-wrap:wrap; gap:6px; }\n  .sc{\n    display:flex; flex-direction:column; align-items:center; gap:7px;\n    text-decoration:none; padding:3px 12px 12px 12px; border-radius:11px;\n    border:1px solid transparent; transition:.16s;\n  }\n  .sc:hover{ background:var(--hover); border-color:var(--line-2); transform:translateY(-1px); }\n  .sc .tile{\n    width:34px; height:34px; border-radius:10px;\n    display:flex; align-items:center; justify-content:center;\n    font-size:16px; font-weight:700; color:var(--ink);\n    background:var(--card-2); border:1px solid var(--line-2);\n  }\n  .sc .lbl{ font-size:11px; color:var(--ink-2); white-space:nowrap; }\n  .sc.add .tile{ background:transparent; color:var(--ink-3); border-style:dashed; font-weight:400; }\n\n  /* ----- IA rapide : grille 3x3 dans sa propre bulle ----- */\n  .ai-mini{\n    display:grid; grid-template-columns:repeat(3,32px); gap:11px;\n    justify-content:center; align-content:center;\n  }\n  .ai-mini a{\n    width:32px; height:32px;\n    display:flex; align-items:center; justify-content:center;\n    border-radius:9px; text-decoration:none;\n    font-size:13px; font-weight:700; line-height:1;\n    border:1px solid rgba(255,255,255,.12);\n    transition:transform .16s, filter .16s, box-shadow .16s;\n  }\n  .ai-mini a:hover{ transform:translateY(-2px); filter:brightness(1.08); box-shadow:0 6px 16px rgba(0,0,0,.4); }\n\n  /* ----- favorite groups ----- */\n  .groups{ display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); }\n  .group .g-head{ display:flex; align-items:center; gap:8px; margin-bottom:12px; }\n  .group .dot{ width:7px; height:7px; border-radius:50%; background:var(--ink-4); }\n  .group .g-name{ font-size:13px; font-weight:500; color:var(--ink); }\n  .group .g-count{ font-size:11px; color:var(--ink-4); margin-left:auto; }\n  .chips{ display:flex; flex-wrap:wrap; gap:7px; }\n  .chip{\n    font-size:12px; color:var(--ink-2); text-decoration:none;\n    background:var(--bg-2); border:1px solid var(--line); border-radius:8px;\n    padding:6px 11px; transition:.15s; white-space:nowrap;\n  }\n  .chip:hover{ color:var(--accent); border-color:var(--accent-line); }\n\n  /* ----- recently ----- */\n  .recent{ display:flex; align-items:center; gap:12px; text-decoration:none; padding:9px 0; border-top:1px solid var(--line); }\n  .recent:first-of-type{ border-top:0; }\n  .recent .fav{\n    width:26px; height:26px; border-radius:7px; flex:none;\n    display:flex; align-items:center; justify-content:center;\n    font-size:12px; font-weight:700; color:var(--ink-2);\n    background:var(--card-2); border:1px solid var(--line);\n  }\n  .recent .info{ min-width:0; flex:1; }\n  .recent .rt{ font-size:13px; color:var(--ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }\n  .recent:hover .rt{ color:var(--accent); }\n  .recent .rd{ font-size:11px; color:var(--ink-4); }\n  .recent .rtime{ font-size:11px; color:var(--ink-4); flex:none; }\n\n  /* ----- settings gear (page + panels) ----- */\n  .head-right{ display:flex; align-items:center; gap:11px; }\n  .head-right .meta{ font-size:12px; color:var(--ink-3); white-space:nowrap; }\n  .gear{\n    display:inline-flex; align-items:center; justify-content:center;\n    width:30px; height:30px; padding:0; flex:none;\n    border:1px solid transparent; border-radius:9px; background:transparent;\n    color:var(--ink-4); cursor:pointer; transition:color .15s, background .15s, border-color .15s, transform .3s;\n  }\n  .gear:hover{ color:var(--accent); background:var(--hover); border-color:var(--line); }\n  .gear:hover svg{ transform:rotate(40deg); }\n  .gear svg{ width:17px; height:17px; transition:transform .3s ease; }\n  .page-gear{ position:absolute; top:40px; right:48px; width:40px; height:40px; }\n  .page-gear svg{ width:20px; height:20px; }\n\n  /* ----- IA launcher ----- */\n  .ai-grid{ display:flex; flex-wrap:wrap; gap:12px; }\n  .ai-tile{\n    width:52px; height:52px; flex:none;\n    display:flex; align-items:center; justify-content:center;\n    border-radius:14px; text-decoration:none;\n    font-size:21px; font-weight:700; line-height:1;\n    border:1px solid rgba(255,255,255,.12);\n    transition:transform .16s, box-shadow .16s, filter .16s;\n  }\n  .ai-tile:hover{ transform:translateY(-2px); filter:brightness(1.08); box-shadow:0 7px 20px rgba(0,0,0,.4); }\n\n  /* ----- agenda (mensuel) ----- */\n  .cal-nav{ font-size:17px; line-height:1; font-weight:500; }\n  .cal-month{ min-width:104px; text-align:center; text-transform:capitalize; color:var(--ink-2); }\n  .cal-weekdays{ display:grid; grid-template-columns:repeat(7,1fr); gap:8px; margin-bottom:8px; }\n  .cal-weekdays span{ font-size:11px; text-transform:uppercase; letter-spacing:.08em; color:var(--ink-4); padding-left:3px; }\n  .cal-grid{ display:grid; grid-template-columns:repeat(7,1fr); grid-auto-rows:84px; gap:8px; }\n  .cal-day{\n    height:84px; overflow:hidden; border:1px solid var(--line); border-radius:10px;\n    padding:7px 8px; background:var(--bg-2);\n    display:flex; flex-direction:column; gap:4px;\n  }\n  .cal-day.out{ background:transparent; border-color:transparent; }\n  .cal-day .num{ font-size:12px; color:var(--ink-3); align-self:flex-start; }\n  .cal-day.today{ border-color:var(--accent-line); }\n  .cal-day.today .num{\n    background:var(--accent); color:#17191a; font-weight:600;\n    width:21px; height:21px; border-radius:50%;\n    display:flex; align-items:center; justify-content:center;\n  }\n  .cal-ev{\n    font-size:11px; color:var(--accent); background:var(--accent-soft);\n    border-radius:6px; padding:2px 7px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;\n  }\n  .cal-more{ font-size:10px; color:var(--ink-4); padding-left:2px; }\n\n  /* ================= RESPONSIVE ================= */\n  @media (max-width:1080px){\n    .wrap{ padding:34px 30px 48px; }\n    .hero{ grid-template-columns:1fr; align-items:flex-start; gap:24px; }\n    .zones{ flex-wrap:wrap; }\n    .col4,.col5,.col7,.col8{ grid-column:span 6; }\n    .bento-col.col8,.bento-col.col4{ grid-column:span 12; }\n    .col10{ grid-column:span 8; }\n    .col2{ grid-column:span 4; }    .grid-sc{ grid-template-columns:repeat(6,1fr); }\n    .groups{ grid-template-columns:repeat(2,1fr); }\n  }\n  @media (max-width:680px){\n    .wrap{ padding:26px 18px 40px; }\n    .clock{ font-size:54px; }\n    .search{ flex-wrap:wrap; }\n    .search input{ order:2; flex-basis:100%; }\n    .seg{ margin-left:auto; }\n    .col4,.col5,.col7,.col8,.col12{ grid-column:span 12; }\n    .duo{ grid-template-columns:1fr; }    .grid-sc{ grid-template-columns:repeat(4,1fr); }\n    .zone{ flex:1; }\n    .page-gear{ top:24px; right:18px; }\n  }\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n<main class=\"wrap\">\n\n  <button type=\"button\" class=\"gear page-gear\" id=\"pageGear\" aria-label=\"Paramètres\"><\u002Fbutton>\n\n  <!-- ===================== HERO ===================== -->\n  <header class=\"hero\">\n    <div>\n      <p class=\"greeting\"><span id=\"greet\">Bonsoir<\u002Fspan>, <b>Dorian<\u002Fb><\u002Fp>\n      <div class=\"clock tnum\">\n        <span id=\"hm\">--:--<\u002Fspan><span class=\"sec\" id=\"sec\">00<\u002Fspan>\n      <\u002Fdiv>\n      <p class=\"date\" id=\"date\">—<\u002Fp>\n    <\u002Fdiv>\n\n    <div class=\"zones\" id=\"zones\">\n      <!-- timezone cards injected -->\n    <\u002Fdiv>\n  <\u002Fheader>\n\n  <!-- ===================== SEARCH ===================== -->\n  <form class=\"search\" id=\"searchForm\" role=\"search\" autocomplete=\"off\" style=\"height: 42px; padding: 7px 7px 7px 14px\">\n    <svg class=\"glass\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n      <circle cx=\"11\" cy=\"11\" r=\"7\" stroke=\"currentColor\" stroke-width=\"1.7\"><\u002Fcircle>\n      <path d=\"m20 20-3.2-3.2\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\"><\u002Fpath>\n    <\u002Fsvg>\n    <input id=\"q\" type=\"text\" placeholder=\"Rechercher sur le web…\" aria-label=\"Recherche\">\n    <div class=\"seg\" role=\"group\" aria-label=\"Moteur de recherche\" style=\"height: 32px\">\n      <button type=\"button\" data-engine=\"google\" aria-pressed=\"true\" style=\"text-align: left; padding: 2px 12px 1px\">Google<\u002Fbutton>\n      <button type=\"button\" data-engine=\"gemini\" aria-pressed=\"false\" style=\"padding: 2px 12px 1px\">Gemini<\u002Fbutton>\n      <button type=\"button\" data-engine=\"claude\" aria-pressed=\"false\" style=\"padding: 2px 12px 1px\">Claude<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fform>\n\n  <!-- ===================== BENTO ===================== -->\n  <div class=\"bento\">\n\n    <!-- SHORTCUTS -->\n    <section class=\"card soft col10\" style=\"padding: 4px 12px 10px; height: 208px\">\n      <div class=\"card-head\" style=\"line-height: 1.45; height: 24px\">\n        <span class=\"card-title\">Raccourcis<\u002Fspan>\n        <span class=\"head-right\"><\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"grid-sc\" id=\"shortcuts\" style=\"text-align: left; opacity: 1; letter-spacing: 0px; font-weight: 500; height: 100px\"><\u002Fdiv>\n    <\u002Fsection>\n\n    <!-- IA RAPIDE -->\n    <section class=\"card soft col2\" style=\"padding: 12px; height: 208px\">\n      <div class=\"ai-mini\" id=\"aiMini\" style=\"text-align: center\"><\u002Fdiv>\n    <\u002Fsection>\n\n    <!-- ===== LEFT COLUMN : météo + bourse, puis agenda ===== -->\n    <div class=\"bento-col col8\">\n      <div class=\"duo\">\n        <!-- WEATHER -->\n        <section class=\"card\" style=\"padding: 4px 12px 12px\">\n      <div class=\"card-head\" style=\"height: 24px\">\n        <span class=\"card-title\">Météo<\u002Fspan>\n        <span class=\"head-right\"><span class=\"meta\">Dijon · maintenant<\u002Fspan><\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"wx-now\">\n        <div>\n          <div class=\"wx-temp tnum\">18°<\u002Fdiv>\n          <div class=\"wx-cond\">Partiellement nuageux<\u002Fdiv>\n          <div class=\"wx-sub\">Ressenti 16° · Vent 12 km/h<\u002Fdiv>\n        <\u002Fdiv>\n        <div>\n          <div class=\"wx-glyph\" style=\"width: 84px; height: 84px\">⛅<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"wx-days\">\n        <div class=\"wx-day\"><div class=\"d\">Sam<\u002Fdiv><div class=\"g\">☀️<\u002Fdiv><div class=\"t tnum\"><b>21°<\u002Fb> <span>11°<\u002Fspan><\u002Fdiv><\u002Fdiv>\n        <div class=\"wx-day\"><div class=\"d\">Dim<\u002Fdiv><div class=\"g\">🌦️<\u002Fdiv><div class=\"t tnum\"><b>17°<\u002Fb> <span>10°<\u002Fspan><\u002Fdiv><\u002Fdiv>\n        <div class=\"wx-day\"><div class=\"d\">Lun<\u002Fdiv><div class=\"g\">⛅<\u002Fdiv><div class=\"t tnum\"><b>19°<\u002Fb> <span>12°<\u002Fspan><\u002Fdiv><\u002Fdiv>\n        <div class=\"wx-day\"><div class=\"d\">Mar<\u002Fdiv><div class=\"g\">🌧️<\u002Fdiv><div class=\"t tnum\"><b>15°<\u002Fb> <span>9°<\u002Fspan><\u002Fdiv><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fsection>\n\n        <!-- STOCKS -->\n        <section class=\"card\" style=\"padding: 4px 12px 12px\">\n          <div class=\"card-head\" style=\"height: 24px\">\n            <span class=\"card-title\">Bourse<\u002Fspan>\n            <span class=\"head-right\"><span class=\"meta\">7 j · ouverts<\u002Fspan><\u002Fspan>\n          <\u002Fdiv>\n          <div id=\"stocks\"><\u002Fdiv>\n        <\u002Fsection>\n      <\u002Fdiv>\n\n      <!-- AGENDA -->\n      <section class=\"card\">\n      <div class=\"card-head\">\n        <span class=\"card-title\">Agenda<\u002Fspan>\n        <span class=\"head-right\">\n          <button type=\"button\" class=\"gear cal-nav\" data-cal=\"-1\" aria-label=\"Mois précédent\">‹<\u002Fbutton>\n          <span class=\"meta cal-month\" id=\"calMonth\">—<\u002Fspan>\n          <button type=\"button\" class=\"gear cal-nav\" data-cal=\"1\" aria-label=\"Mois suivant\">›<\u002Fbutton>\n        <\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"cal-weekdays\">\n        <span>Lun<\u002Fspan><span>Mar<\u002Fspan><span>Mer<\u002Fspan><span>Jeu<\u002Fspan><span>Ven<\u002Fspan><span>Sam<\u002Fspan><span>Dim<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"cal-grid\" id=\"calGrid\"><\u002Fdiv>\n      <\u002Fsection>\n    <\u002Fdiv>\n\n    <!-- ===== RIGHT COLUMN : actualités, puis récemment ===== -->\n    <div class=\"bento-col col4\">\n      <!-- NEWS -->\n      <section class=\"card\" style=\"padding: 4px 12px 12px; height: 545px\">\n        <div class=\"card-head\" style=\"height: 24px\">\n          <span class=\"card-title\">Actualités<\u002Fspan>\n          <span class=\"head-right\"><\u002Fspan>\n        <\u002Fdiv>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">L'Europe dévoile son nouveau plan d'investissement dans les semi-conducteurs<\u002Fdiv><div class=\"m\"><b>Le Monde<\u002Fb> · il y a 12 min<\u002Fdiv><\u002Fa>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">Les taux directeurs maintenus, la BCE reste prudente face à l'inflation<\u002Fdiv><div class=\"m\"><b>Les Échos<\u002Fb> · il y a 38 min<\u002Fdiv><\u002Fa>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">Open source : une nouvelle fondation pour soutenir les modèles ouverts<\u002Fdiv><div class=\"m\"><b>Next<\u002Fb> · il y a 1 h<\u002Fdiv><\u002Fa>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">Ligue 1 : la billetterie de la nouvelle saison ouvre lundi<\u002Fdiv><div class=\"m\"><b>L'Équipe<\u002Fb> · il y a 2 h<\u002Fdiv><\u002Fa>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">Espace : le télescope renvoie ses premières images en haute résolution<\u002Fdiv><div class=\"m\"><b>France Info<\u002Fb> · il y a 3 h<\u002Fdiv><\u002Fa>\n        <a class=\"news-item\" href=\"#\"><div class=\"t\">Automobile : les ventes de véhicules électriques en hausse de 18 % sur un an<\u002Fdiv><div class=\"m\"><b>Le Figaro<\u002Fb> · il y a 4 h<\u002Fdiv><\u002Fa>\n      <\u002Fsection>\n\n      <!-- RECENTLY VISITED -->\n      <section class=\"card\" style=\"padding: 4px 12px 12px\">\n        <div class=\"card-head\" style=\"height: 24px\">\n          <span class=\"card-title\">Récemment consultées<\u002Fspan>\n          <span class=\"head-right\"><\u002Fspan>\n        <\u002Fdiv>\n        <div id=\"recent\"><\u002Fdiv>\n      <\u002Fsection>\n    <\u002Fdiv>\n\n  <\u002Fdiv>\n<\u002Fmain>\n\n<script>\n(function(){\n  /* ---------- greeting + clock + date ---------- */\n  const $ = s => document.querySelector(s);\n  const greetEl=$(\"#greet\"), hmEl=$(\"#hm\"), secEl=$(\"#sec\"), dateEl=$(\"#date\");\n\n  function greetingFor(h){\n    if(h<5)  return \"Bonne nuit\";\n    if(h<12) return \"Bonjour\";\n    if(h<18) return \"Bon après-midi\";\n    return \"Bonsoir\";\n  }\n  const dateFmt = new Intl.DateTimeFormat(\"fr-FR\",{weekday:\"long\",day:\"numeric\",month:\"long\",year:\"numeric\"});\n  const pad = n => String(n).padStart(2,\"0\");\n\n  function tick(){\n    const now=new Date();\n    greetEl.textContent = greetingFor(now.getHours());\n    hmEl.textContent = pad(now.getHours())+\":\"+pad(now.getMinutes());\n    secEl.textContent = pad(now.getSeconds());\n    dateEl.textContent = dateFmt.format(now);\n  }\n  tick(); setInterval(tick,1000);\n\n  /* ---------- timezone cards ---------- */\n  const ZONES=[\n    {city:\"Paris\",     tz:\"Europe/Paris\",    meta:\"GMT+2\"},\n    {city:\"New York\",  tz:\"America/New_York\",meta:\"GMT−4\"},\n    {city:\"Tokyo\",     tz:\"Asia/Tokyo\",      meta:\"GMT+9\"},\n  ];\n  const zonesEl=$(\"#zones\");\n  zonesEl.innerHTML = ZONES.map(z=>`\n    <div class=\"zone\">\n      <div class=\"city\">${z.city}<\u002Fdiv>\n      <div class=\"ztime tnum\" data-tz=\"${z.tz}\">--:--<\u002Fdiv>\n      <div class=\"zmeta\">${z.meta}<\u002Fdiv>\n    <\u002Fdiv>`).join(\"\");\n\n  function tickZones(){\n    document.querySelectorAll(\".ztime\").forEach(el=>{\n      el.textContent = new Intl.DateTimeFormat(\"fr-FR\",{hour:\"2-digit\",minute:\"2-digit\",hour12:false,timeZone:el.dataset.tz}).format(new Date());\n    });\n  }\n  tickZones(); setInterval(tickZones,1000*15);\n\n  /* ---------- search engine toggle ---------- */\n  let engine=\"google\";\n  const segBtns=document.querySelectorAll(\".seg button\");\n  segBtns.forEach(b=>b.addEventListener(\"click\",()=>{\n    engine=b.dataset.engine;\n    segBtns.forEach(x=>x.setAttribute(\"aria-pressed\", String(x===b)));\n    $(\"#q\").focus();\n  }));\n  $(\"#searchForm\").addEventListener(\"submit\",e=>{\n    e.preventDefault();\n    const q=encodeURIComponent($(\"#q\").value.trim());\n    if(!q) return;\n    const url = engine===\"gemini\" ? \"https://gemini.google.com/app?q=\"+q\n              : engine===\"claude\" ? \"https://claude.ai/new?q=\"+q\n              : \"https://www.google.com/search?q=\"+q;\n    window.open(url,\"_blank\",\"noopener\");\n  });\n\n  /* ---------- settings gear (page + every panel) ---------- */\n  const GEAR='<svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"3.1\" stroke=\"currentColor\" stroke-width=\"1.6\"/><path d=\"M19.4 12c0-.5-.05-1-.13-1.47l1.86-1.4-1.9-3.3-2.2.89a7.2 7.2 0 0 0-2.54-1.47L14.08 2.8H9.92l-.32 2.45a7.2 7.2 0 0 0-2.54 1.47l-2.2-.89-1.9 3.3 1.86 1.4c-.08.47-.13.97-.13 1.47s.05 1 .13 1.47l-1.86 1.4 1.9 3.3 2.2-.89a7.2 7.2 0 0 0 2.54 1.47l.32 2.45h4.16l.32-2.45a7.2 7.2 0 0 0 2.54-1.47l2.2.89 1.9-3.3-1.86-1.4c.08-.47.13-.97.13-1.47Z\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linejoin=\"round\"/><\u002Fsvg>';\n  document.querySelectorAll(\".head-right\").forEach(hr=>{\n    const b=document.createElement(\"button\");\n    b.type=\"button\"; b.className=\"gear\"; b.setAttribute(\"aria-label\",\"Paramètres du panneau\");\n    b.innerHTML=GEAR; hr.appendChild(b);\n  });\n  const pg=$(\"#pageGear\"); if(pg) pg.innerHTML=GEAR;\n\n  /* ---------- favoris (icônes uniformes + bouton Ajouter) ---------- */\n  const IC={\n    mail:'<path d=\"M3 6.5A1.5 1.5 0 0 1 4.5 5h15A1.5 1.5 0 0 1 21 6.5v11A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5z\"/><path d=\"m3.5 7 8.5 6 8.5-6\"/>',\n    play:'<polygon points=\"9 6 19 12 9 18\"/>',\n    code:'<path d=\"m9 8-4 4 4 4\"/><path d=\"m15 8 4 4-4 4\"/>',\n    server:'<rect x=\"4\" y=\"4\" width=\"16\" height=\"6.5\" rx=\"1.6\"/><rect x=\"4\" y=\"13.5\" width=\"16\" height=\"6.5\" rx=\"1.6\"/><path d=\"M7.5 7.25h.01M7.5 16.75h.01\"/>',\n    drive:'<polygon points=\"12 5 20 19 4 19\"/>',\n    doc:'<rect x=\"5.5\" y=\"3.5\" width=\"13\" height=\"17\" rx=\"2\"/><path d=\"M9 8.5h6M9 12h6M9 15.5h4\"/>',\n    chat:'<path d=\"M4 5.5h16v9.5h-6.5L10 19v-4H4z\"/>',\n    calendar:'<rect x=\"4\" y=\"5\" width=\"16\" height=\"15\" rx=\"2\"/><path d=\"M4 9.5h16M8.5 3v4M15.5 3v4\"/>',\n    music:'<path d=\"M9 18V6l10-2v12\"/><circle cx=\"6.5\" cy=\"18\" r=\"2.5\"/><circle cx=\"16.5\" cy=\"16\" r=\"2.5\"/>',\n    cloud:'<path d=\"M7 18h10a4 4 0 0 0 .5-7.97A6 6 0 0 0 5.8 9.2 3.5 3.5 0 0 0 7 18Z\"/>',\n    terminal:'<rect x=\"3\" y=\"4\" width=\"18\" height=\"16\" rx=\"2\"/><path d=\"m7 9 3 3-3 3M13 15h4\"/>',\n    game:'<rect x=\"3\" y=\"7.5\" width=\"18\" height=\"9\" rx=\"4.5\"/><path d=\"M7.5 11v2.5M6.25 12.25h2.5\"/><circle cx=\"16\" cy=\"11.6\" r=\".9\"/><circle cx=\"17.6\" cy=\"13.4\" r=\".9\"/>',\n    bag:'<path d=\"M6 8h12l-1 12H7z\"/><path d=\"M9 8a3 3 0 0 1 6 0\"/>',\n    pin:'<path d=\"M12 21s7-6.5 7-11a7 7 0 1 0-14 0c0 4.5 7 11 7 11Z\"/><circle cx=\"12\" cy=\"10\" r=\"2.5\"/>',\n    image:'<rect x=\"4\" y=\"5\" width=\"16\" height=\"14\" rx=\"2\"/><circle cx=\"9\" cy=\"10\" r=\"1.6\"/><path d=\"m5 17 5-4 4 3 3-2 2 2\"/>',\n    globe:'<circle cx=\"12\" cy=\"12\" r=\"8\"/><path d=\"M4 12h16M12 4c2.5 2.5 2.5 13 0 16M12 4c-2.5 2.5-2.5 13 0 16\"/>',\n    star:'<path d=\"m12 4 2.3 5 5.2.5-3.9 3.5 1.2 5.1L12 20l-4.8 2.6 1.2-5.1L4.5 13l5.2-.5z\"/>',\n    bolt:'<path d=\"M13 3 5 13h6l-1 8 8-10h-6z\"/>',\n    plus:'<path d=\"M12 5.5v13M5.5 12h13\"/>'\n  };\n  const svg = p => `<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\">${p}<\u002Fsvg>`;\n  const SHORTCUTS=[\n    {l:\"Gmail\",     i:\"mail\",     bg:\"#e5544b\"},\n    {l:\"YouTube\",   i:\"play\",     bg:\"#f0463f\"},\n    {l:\"GitHub\",    i:\"code\",     bg:\"#3a3f47\"},\n    {l:\"Proxmox\",   i:\"server\",   bg:\"#e08a3c\"},\n    {l:\"Drive\",     i:\"drive\",    bg:\"#4d8bf0\"},\n    {l:\"Notion\",    i:\"doc\",      bg:\"#d4d7de\", fg:\"#16181d\"},\n    {l:\"Twitch\",    i:\"chat\",     bg:\"#9b6bf2\"},\n    {l:\"Agenda\",    i:\"calendar\", bg:\"#2f9e6f\"},\n    {l:\"Spotify\",   i:\"music\",    bg:\"#1db954\"},\n    {l:\"Météo\",     i:\"cloud\",    bg:\"#5b9bf5\"},\n    {l:\"Terminal\",  i:\"terminal\", bg:\"#2c3138\"},\n    {l:\"Steam\",     i:\"game\",     bg:\"#3a6ea5\"},\n    {l:\"Boutique\",  i:\"bag\",      bg:\"#e0912f\"},\n    {l:\"Carte\",     i:\"pin\",      bg:\"#d96d6d\"},\n    {l:\"Photos\",    i:\"image\",    bg:\"#c77fd0\"},\n    {l:\"Web\",       i:\"globe\",    bg:\"#3aa0a0\"},\n    {l:\"Favoris\",   i:\"star\",     bg:\"#e0b13c\"},\n    {l:\"Domotique\", i:\"bolt\",     bg:\"#cf8a4a\"},\n    {l:\"Ajouter\",   i:\"plus\",     add:true},\n  ];\n  $(\"#shortcuts\").innerHTML = SHORTCUTS.map(s=>`\n    <a class=\"sc ${s.add?'add':''}\" href=\"#\" title=\"${s.l}\" aria-label=\"${s.l}\">\n      <span class=\"tile\" ${s.add?'':`style=\"background:${s.bg};color:${s.fg||'#fff'};border-color:rgba(255,255,255,.14)\"`}>${svg(IC[s.i])}<\u002Fspan>\n    <\u002Fa>`).join(\"\");\n\n  /* ---------- stocks + 7-day sparkline ---------- */\n  function spark(data,dir){\n    const w=74,h=30,pad=3, lo=Math.min(...data), hi=Math.max(...data), rng=(hi-lo)||1;\n    const pts=data.map((v,i)=>{\n      const x=pad+i*(w-2*pad)/(data.length-1);\n      const y=h-pad-((v-lo)/rng)*(h-2*pad);\n      return x.toFixed(1)+\",\"+y.toFixed(1);\n    });\n    const col=dir===\"up\"?\"var(--up)\":\"var(--down)\";\n    const fill=dir===\"up\"?\"rgba(95,208,160,.13)\":\"rgba(240,122,122,.13)\";\n    return `<svg class=\"spark\" viewBox=\"0 0 ${w} ${h}\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n      <polyline points=\"${pad},${h} ${pts.join(\" \")} ${w-pad},${h}\" fill=\"${fill}\" stroke=\"none\"/>\n      <polyline points=\"${pts.join(\" \")}\" fill=\"none\" stroke=\"${col}\" stroke-width=\"1.5\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n    <\u002Fsvg>`;\n  }\n  const STOCKS=[\n    {n:\"CAC 40\",     s:\"Euronext Paris\", p:\"7 842,15\", c:\"+0,84 %\", dir:\"up\",   d:[7710,7735,7702,7768,7790,7775,7842]},\n    {n:\"MSCI World\", s:\"ETF · IWDA\",     p:\"102,47 €\", c:\"+0,31 %\", dir:\"up\",   d:[101.1,101.4,101.2,101.8,102.0,102.2,102.47]},\n    {n:\"Bitcoin\",    s:\"BTC / EUR\",      p:\"61 380 €\", c:\"−1,92 %\", dir:\"down\", d:[63800,63200,62500,62900,62100,61900,61380]},\n    {n:\"Ethereum\",   s:\"ETH / EUR\",      p:\"3 248 €\",  c:\"−0,57 %\", dir:\"down\", d:[3360,3330,3290,3310,3270,3260,3248]},\n  ];\n  $(\"#stocks\").innerHTML = STOCKS.map(s=>`\n    <div class=\"row\">\n      <div class=\"name\">${s.n}<small>${s.s}<\u002Fsmall><\u002Fdiv>\n      ${spark(s.d,s.dir)}\n      <div class=\"right\"><div class=\"price tnum\">${s.p}<\u002Fdiv><div class=\"chg ${s.dir} tnum\">${s.c}<\u002Fdiv><\u002Fdiv>\n    <\u002Fdiv>`).join(\"\");\n\n  /* ---------- IA launcher (logos en placeholder, sans noms) ---------- */\n  const AIS=[\n    {n:\"ChatGPT\",    g:\"O\", bg:\"#0f9d76\", u:\"https://chatgpt.com\"},\n    {n:\"Gemini\",     g:\"G\", bg:\"#4d8bf0\", u:\"https://gemini.google.com\"},\n    {n:\"Claude\",     g:\"C\", bg:\"#d97757\", u:\"https://claude.ai\"},\n    {n:\"Perplexity\", g:\"P\", bg:\"#20b8cd\", u:\"https://www.perplexity.ai\"},\n    {n:\"Grok\",       g:\"x\", bg:\"#d4d7de\", fg:\"#16181d\", u:\"https://grok.com\"},\n    {n:\"Kimi\",       g:\"K\", bg:\"#6b5bff\", u:\"https://www.kimi.com\"},\n    {n:\"Mistral\",    g:\"M\", bg:\"#fa520f\", u:\"https://chat.mistral.ai\"},\n    {n:\"DeepSeek\",   g:\"D\", bg:\"#4d6bfe\", u:\"https://chat.deepseek.com\"},\n    {n:\"Copilot\",    g:\"C\", bg:\"#1f9cf0\", u:\"https://copilot.microsoft.com\"},\n    {n:\"Meta AI\",    g:\"M\", bg:\"#0866ff\", u:\"https://www.meta.ai\"},\n    {n:\"Qwen\",       g:\"Q\", bg:\"#615ced\", u:\"https://chat.qwen.ai\"},\n    {n:\"Poe\",        g:\"P\", bg:\"#5a3ff0\", u:\"https://poe.com\"},\n    {n:\"HuggingChat\",g:\"H\", bg:\"#e0a93c\", fg:\"#16181d\", u:\"https://huggingface.co/chat\"},\n    {n:\"Phind\",      g:\"P\", bg:\"#2bb8a3\", u:\"https://www.phind.com\"},\n    {n:\"You.com\",    g:\"Y\", bg:\"#7a5cff\", u:\"https://you.com\"},\n  ];\n  /* ---------- IA rapide : grille 3 colonnes ---------- */\n  const mini=$(\"#aiMini\");\n  if(mini) mini.innerHTML = AIS.slice(0,12).map(a=>`\n    <a href=\"${a.u}\" target=\"_blank\" rel=\"noopener\" title=\"${a.n}\" aria-label=\"${a.n}\" style=\"background:${a.bg};color:${a.fg||'#fff'}\">${a.g}<\u002Fa>`).join(\"\");\n\n  /* ---------- recently visited ---------- */\n  const RECENT=[\n    {t:\"Documentation – Proxmox VE\", d:\"pve.local\",            f:\"P\", time:\"14:02\"},\n    {t:\"console.anthropic.com\",      d:\"anthropic.com\",        f:\"A\", time:\"13:48\"},\n    {t:\"Pull request #284\",          d:\"github.com\",           f:\"G\", time:\"13:20\"},\n    {t:\"Portefeuille\",               d:\"trade-republic.com\",   f:\"T\", time:\"11:57\"},\n    {t:\"r/selfhosted\",               d:\"reddit.com\",           f:\"R\", time:\"09:31\"},\n    {t:\"Boîte de réception\",         d:\"mail.google.com\",      f:\"M\", time:\"08:44\"},\n  ];\n  $(\"#recent\").innerHTML = RECENT.map(r=>`\n    <a class=\"recent\" href=\"#\">\n      <span class=\"fav\">${r.f}<\u002Fspan>\n      <span class=\"info\">\n        <span class=\"rt\">${r.t}<\u002Fspan>\n        <span class=\"rd\">${r.d}<\u002Fspan>\n      <\u002Fspan>\n      <span class=\"rtime tnum\">${r.time}<\u002Fspan>\n    <\u002Fa>`).join(\"\");\n\n  /* ---------- agenda (mensuel, placeholder) ---------- */\n  const MOIS=[\"janvier\",\"février\",\"mars\",\"avril\",\"mai\",\"juin\",\"juillet\",\"août\",\"septembre\",\"octobre\",\"novembre\",\"décembre\"];\n  const EVENTS={\n    3:[\"Dentiste · 9h\"],\n    6:[\"Footing 8 km\"],\n    9:[\"Sprint review · 14h\",\"1:1 avec Sam\"],\n    13:[\"Déj. Marie · 12h30\",\"Visio homelab · 18h\"],\n    17:[\"Anniv. Léa\"],\n    20:[\"Ciné · 21h\"],\n    22:[\"Congés\"],\n    25:[\"Loyer\"],\n    28:[\"Concert · 20h\"],\n    30:[\"Bilan mensuel · 16h\"],\n  };\n  let calY, calM;\n  function renderCal(y,m){\n    const grid=$(\"#calGrid\"); if(!grid) return;\n    $(\"#calMonth\").textContent = MOIS[m]+\" \"+y;\n    const off=(new Date(y,m,1).getDay()+6)%7;          // lundi = 0\n    const dim=new Date(y,m+1,0).getDate();\n    const weeks=Math.ceil((off+dim)/7);\n    const t=new Date();\n    let html=\"\";\n    for(let i=0;i<weeks*7;i++){\n      const dn=i-off+1;\n      if(dn<1||dn>dim){ html+='<div class=\"cal-day out\"><\u002Fdiv>'; continue; }\n      const today = y===t.getFullYear() && m===t.getMonth() && dn===t.getDate();\n      const evs=EVENTS[dn]||[];\n      const chips=evs.slice(0,2).map(e=>`<span class=\"cal-ev\" title=\"${e}\">${e}<\u002Fspan>`).join(\"\");\n      const more=evs.length>2?`<span class=\"cal-more\">+${evs.length-2}<\u002Fspan>`:\"\";\n      html+=`<div class=\"cal-day${today?' today':''}\"><span class=\"num tnum\">${dn}<\u002Fspan>${chips}${more}<\u002Fdiv>`;\n    }\n    grid.innerHTML=html;\n  }\n  (function(){ const n=new Date(); calY=n.getFullYear(); calM=n.getMonth(); renderCal(calY,calM); })();\n  document.querySelectorAll(\".cal-nav\").forEach(b=>b.addEventListener(\"click\",()=>{\n    calM+=parseInt(b.dataset.cal,10);\n    if(calM<0){ calM=11; calY--; }\n    if(calM>11){ calM=0; calY++; }\n    renderCal(calY,calM);\n  }));\n})();\n<\u002Fscript>\n\n\n<style id=\"__om-edit-overrides\">\n.col12 :is(h1,h2,h3,h4,h5,h6,p,li,dt,dd,blockquote,figcaption,label,span,a,em,strong,small,td,th,caption) >[aria-label=\"Paramètres du panneau\"] { text-align: center !important }\n#aiMini >[aria-label=\"ChatGPT\"] { width: 32px !important }\n#aiMini >[aria-label=\"ChatGPT\"] { height: 32px !important }\n#aiMini >[aria-label=\"Gemini\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"Claude\"] { width: 32px !important }\n#aiMini >[aria-label=\"Perplexity\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"Grok\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"Kimi\"] { width: 32px !important }\n#aiMini >[aria-label=\"Mistral\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"DeepSeek\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"Copilot\"] { width: 32px !important }\n#aiMini >[aria-label=\"Claude\"] { height: 32px !important }\n#aiMini >[aria-label=\"Kimi\"] { height: 32px !important }\n#aiMini >[aria-label=\"Copilot\"] { height: 32px !important }\n#aiMini >[aria-label=\"Meta AI\"] { width: 32px !important }\n#aiMini >[aria-label=\"Qwen\"] { width: 32px !important }\n#aiMini >[aria-label=\"Poe\"] { height: 32px !important }\n#aiMini >[aria-label=\"HuggingChat\"] { width: 32px !important; height: 32px !important }\n#aiMini >[aria-label=\"Phind\"] { width: 32px !important }\n#aiMini >[aria-label=\"You.com\"] { height: 32px !important }\n#aiMini >[aria-label=\"You.com\"] { width: 32px !important }\n<\u002Fstyle>\n<\u002Fbody><\u002Fhtml>"
